# KhaysAlpha AI Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Google Gemini API Key
# Get it from: https://ai.google.dev/
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# REQUIRED: PostgreSQL Database URL
# Format: postgresql://user:password@host:port/database
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/khaysalpha

# ============================================
# OPTIONAL: Server Configuration
# Default port is 5000 if not specified
# ============================================
PORT=5000

# ============================================
# OPTIONAL: Environment Mode
# Can be: development, production
# ============================================
NODE_ENV=development
